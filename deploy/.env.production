# ============================================
# 中试 AI 助手 — 生产环境变量模板
# ============================================
# 使用方式：
#   1. 复制此文件为 deploy/.env （不入库！）
#   2. 填入真实值
#   3. docker compose 会自动加载
# ============================================

# ── LLM 配置 ──────────────────────
# 供应商: deepseek | openai | qwen | anthropic | google
AI_PROVIDER=deepseek
AI_API_KEY=sk-your-real-api-key-here
AI_MODEL=deepseek-v4-flash

# ── SQL Server 配置 ───────────────
# ⚠️ 生产环境必须使用只读账号！不要用 sa！
SQL_HOST=172.18.28.88
SQL_PORT=1433
SQL_DB=db1
SQL_USER=comm_plm_prd
SQL_PASSWORD=Gs05eC@5-1

# ── Web 前端配置 ──────────────────
# Web 调用 Server API 的地址（容器内通过 docker network 通信）
AI_API_URL=http://agent:8000

# ── Server 配置 ───────────────────
PORT=8000
NODE_ENV=production
NODE_OPTIONS=--max-old-space-size=4096

# ── CORS（生产环境必须设置为实际域名）──
# 示例：CORS_ORIGIN=http://agent.yourcompany.com
CORS_ORIGIN=*
