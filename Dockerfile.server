# ===== Production Agent Server =====
# Hono SSE 服务 + pi_agent 核心
# 使用 tsx 运行时执行 TypeScript（pi_agent workspace 依赖 TS 源码）

FROM node:22-alpine AS base
WORKDIR /app

# 安装编译 better-sqlite3 所需的依赖（web 的 Prisma 用到）
RUN apk add --no-cache python3 make g++

# ── 依赖层 ──────────────────────
FROM base AS deps
COPY package.json package-lock.json ./
COPY pi_agent/agent/package.json pi_agent/agent/
COPY server/package.json server/

# 安装全部依赖（含 devDependencies，tsx 需要）
RUN npm ci --workspaces --include-workspace-root

# ── 运行层 ──────────────────────
FROM base AS runner
WORKDIR /app

# 从 deps 层复制 node_modules
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/pi_agent/agent/node_modules ./pi_agent/agent/node_modules
COPY --from=deps /app/server/node_modules ./server/node_modules

# 复制源码
COPY pi_agent/ ./pi_agent/
COPY server/ ./server/

# 环境
ENV NODE_ENV=production
ENV PORT=8000
ENV NODE_OPTIONS="--max-old-space-size=4096"

EXPOSE 8000

# 健康检查（Alpine 无 wget，用 Node.js 实现）
HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
  CMD node -e "require('http').get('http://localhost:8000/health',r=>{process.exit(r.statusCode===200?0:1)})"

CMD ["npx", "tsx", "server/src/index.ts"]
