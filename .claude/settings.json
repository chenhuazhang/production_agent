{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "PowerShell(*)",
      "Agent(*)",
      "Skill(*)",
      "TodoWrite(*)",
      "TaskOutput(*)",
      "TaskStop(*)",
      "EnterPlanMode(*)",
      "ExitPlanMode(*)",
      "AskUserQuestion(*)",
      "SendMessage(*)",
      "CronCreate(*)",
      "CronDelete(*)",
      "Monitor(*)",
      "ScheduleWakeup(*)",
      "PushNotification(*)",
      "Workflow(*)",
      "NotebookEdit(*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "git add -A && git diff --cached --quiet || git commit -m \"auto: Claude session changes\"",
            "shell": "bash"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "git add -A && git diff --cached --quiet || git commit -m \"auto: file changes via Claude\"",
            "shell": "bash"
          }
        ]
      }
    ]
  }
}