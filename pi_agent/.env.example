# ===== AI 模型配置 =====
# 供应商：deepseek | openai | qwen | anthropic | google 等（pi-ai 支持 20+）
# 自定义供应商（如 bailian/阿里云百炼）需在 ~/.pi/agent/models.json 中定义
AI_PROVIDER=bailian
AI_API_KEY=your-api-key
# 模型名（按 provider 而定），当前使用阿里云百炼 GLM-5.2
AI_MODEL=glm-5.2

# 可选：自定义 OpenAI 兼容端点（用于通义/智谱等兼容服务）
# 注意：AI_BASE_URL 不在此项目代码中直接使用。
# 自定义端点请通过 ~/.pi/agent/models.json 配置，例：
# {
#   "providers": {
#     "bailian": {
#       "baseUrl": "https://llm-e4vqdf5des2wlxkk.cn-beijing.maas.aliyuncs.com/compatible-mode/v1",
#       "api": "openai-completions",
#       "apiKey": "BAILIAN_API_KEY",
#       "models": [{ "id": "glm-5.2", "api": "openai-completions" }]
#     }
#   }
# }

# ===== 服务端口 =====
PORT=8000

# ===== SQL Server（中试生产管理库） =====
# query_order_progress 工具直连此库查询真实进度
SQL_HOST=your-sqlserver-host
SQL_PORT=1433
SQL_DB=your-database
SQL_USER=sa
SQL_PASSWORD=your-password
